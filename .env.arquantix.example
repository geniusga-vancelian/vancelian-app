# Copier vers .env.arquantix et adapter (ne pas committer les secrets réels).
# Source de vérité : aligner DB_NAME / ports avec services/arquantix/api/.env.local et web/.env.local pour l’hôte.

# Stack locale par défaut (recovery = même volume DB, namespace Docker distinct si « arquantix » est cassé)
COMPOSE_PROJECT_NAME=arquantixrecovery
ARQUANTIX_COMPOSE_FILE=docker-compose.arquantix-recovery.yml
ARQUANTIX_RECOVERY_PROJECT=arquantixrecovery

# Métadonnées DB (scripts, cohérence). DB_PORT = port PUBLIÉ sur l’hôte (mapping compose).
DB_HOST=arquantix-db
DB_PORT=5443
DB_NAME=arquantix_fresh
DB_USER=arquantix
DB_PASSWORD=change_me

REDIS_PORT=6379
# Dans les conteneurs API : surchargé par compose en redis://arquantix-redis:6379/0
REDIS_URL=redis://arquantix-redis:6379/0

GOOGLE_MAPS_API_KEY=REPLACE_ME

JWT_SECRET_KEY=your-secret-key-change-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
ADMIN_SEED_EMAIL=you@example.com
ADMIN_SEED_PASSWORD=change_me

CORS_ORIGINS=http://localhost:3000
API_PORT=8000

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
WEB_PORT=3000

# Cloudflare R2 (Next.js : upload médias, /api/admin/media/*/file, présignatures).
# Conteneur arquantix-web : env_file = .env puis .env.arquantix (voir docker-compose.arquantix-recovery.yml).
# Tu peux mettre les clés uniquement dans .env racine, uniquement ici, ou les deux (dernier fichier gagne si doublon).
# R2_ENDPOINT=https://xxxxxxxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=arquantix-media
# R2_PUBLIC_URL=

NODE_ENV=development
BFF_ANONYMOUS_BACKEND_ADMIN_ID=3
ARQUANTIX_ALLOW_UNAUTHENTICATED_APP_ROUTES=1

AUTH_MOBILE_OTP_LOGIN_ENABLED=true
TWO_FACTOR_DEV_FIXED_CODE=111111
TWO_FACTOR_DEV_EXPOSE_CODE=true

# Mock OTP login + création wallet Privy (web + Flutter) — dev uniquement
# PORTAL_PRIVY_OTP_DEV_MOCK_ENABLED=true
# PORTAL_PRIVY_OTP_DEV_FIXED_CODE=111111
# Pas d’e-mail Privy ; jeton stub:local-dev:<email> + adresse EVM mock unique par e-mail
# Requis côté API : PRIVY_EXCHANGE_VERIFICATION_MODE=stub

# Optionnel : Strapi (compose utilise CMS_PORT)
# CMS_PORT=1337

# -----------------------------------------------------------------------------
# Assistance — Mémoire long-terme (Palier 2 D.2, cf. docs/arquantix/MEMORY.md)
# -----------------------------------------------------------------------------
# ASSISTANCE_SUMMARIZER_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Assistance — Multi-agents (Phase 1, cf. docs/arquantix/MULTI_AGENTS.md)
# Toutes ces vars sont optionnelles (fallbacks dans le code Python).
# -----------------------------------------------------------------------------
# Kill-switch global — false = 100% legacy default agent (rollback instantané).
# ASSISTANCE_MULTI_AGENT_ENABLED=true
# Modèle du router (classification d'intention, latence-critique).
# ASSISTANCE_AGENT_ROUTER_MODEL=gpt-4o-mini
# ASSISTANCE_ROUTER_TEMPERATURE=0.1
# Seuil sous lequel le router pousse un QCM (clamp [0.0, 1.0]).
# ASSISTANCE_ROUTER_CONFIDENCE_MIN=0.5
# Modèle par agent (override-able indépendamment).
# ASSISTANCE_AGENT_DEFAULT_MODEL=gpt-4o-mini
# ASSISTANCE_AGENT_COMPLIANCE_MODEL=gpt-4o-mini
# ASSISTANCE_AGENT_ADVISOR_MODEL=gpt-4o
# ASSISTANCE_AGENT_PRODUCT_MODEL=gpt-4o-mini
# ASSISTANCE_AGENT_MARKET_MODEL=gpt-4o-mini
# -----------------------------------------------------------------------------
# Assistance — Multi-agents (Phase 2a — Runtime + Compliance L0)
# cf. docs/arquantix/MULTI_AGENTS_RUNTIME.md
# -----------------------------------------------------------------------------
# Active la boucle agentique (function-calling : transactions, KYC, stats, wiki).
# Défaut process : **true**. Mettre **false** uniquement pour rollback (Phase 1 :
# compliance = stub texte sans outils registry OpenAI).
# ASSISTANCE_RUNTIME_LOOP_ENABLED=false
# Liste CSV des agents runtime. Défaut (variable absente) : compliance,product,advisor,market,trust,action.
# ⚠️ Inclure **action** : sans lui, l’agent Actions reste en Phase 1 → pas de run_agent_loop, pas de CAL (crypto_buy / widgets).
# ASSISTANCE_RUNTIME_LOOP_AGENTS=compliance,product,advisor,market,trust,action
# Niveau d'autonomie max par agent (L0=read-only, L1=clarify, L2=mutate, L3=high-risk).
# ASSISTANCE_COMPLIANCE_AUTONOMY_MAX=L0
# ASSISTANCE_ADVISOR_AUTONOMY_MAX=L0
# ASSISTANCE_PRODUCT_AUTONOMY_MAX=L0
# ASSISTANCE_MARKET_AUTONOMY_MAX=L0
# ASSISTANCE_DEFAULT_AUTONOMY_MAX=L0
# Kill-switch global d'autonomie (force tous les agents à L0).
# ASSISTANCE_GLOBAL_AUTONOMY_KILLSWITCH=false
# Limites de la boucle agentique.
# ASSISTANCE_AGENT_MAX_ITER=6
# ASSISTANCE_AGENT_TIMEOUT_SECONDS=45
# ASSISTANCE_TOOL_TIMEOUT_SECONDS=10
# Provider AML externe (mock | sumsub | ...).
# ASSISTANCE_KYC_PROVIDER=mock
# Stream debug "thinking" (iter_count, tools_called) en SSE.
# ASSISTANCE_STREAM_THINKING_ENABLED=true

# -----------------------------------------------------------------------------
# Assistance — Phase 2 wiki + guard-rail product (cf. docs/arquantix/PRODUCT_AGENT.md §9.3)
# -----------------------------------------------------------------------------
# Guard-rail anti-hallucination de l'agent `product` : si le LLM répond sans
# avoir appelé read_product_knowledge / read_wiki_page / show_instrument_card,
# ou s'il appelle select_wiki_pages sans suivre par read_wiki_page, on injecte
# un hint system et on rejoue la boucle UNE seule fois.
# Désactiver uniquement en cas d'incident (rollback rapide).
# ASSISTANCE_PRODUCT_GUARDRAIL_ENABLED=true

# -----------------------------------------------------------------------------
# Assistance — Mémoire long-terme (Palier 2 D.2, cf. docs/arquantix/MEMORY.md §5)
# Défauts révisés 2026-05-04 (mobile-first).
# -----------------------------------------------------------------------------
# Seuil tokens de déclenchement du summarizer. Plancher applicatif 1000.
# Défaut 2500 (ex 6000) : la majorité des sessions Vancelian font 10-30 tours
# < 4000 tokens — à 6000 elles ne contribuaient jamais à la mémoire long-terme.
# ASSISTANCE_SUMMARY_THRESHOLD_TOKENS=2500
#
# Seuil tours alternatif (logique OR avec le seuil tokens). À ≥ 20 messages
# (= min_turns × 2), on consolide indépendamment du volume tokens. Garantit
# que les conv longues mais peu verbeuses (QCM, choix simples) finissent par
# alimenter la mémoire. 0 désactive ce déclencheur (= comportement < 2026-05-04).
# ASSISTANCE_SUMMARY_MIN_TURNS=10
#
# Nombre de tours bruts toujours envoyés post-consolidation.
# ASSISTANCE_RECENT_TURNS_KEPT=8
#
# Temperature du LLM summarizer (bas = factuel).
# ASSISTANCE_SUMMARIZER_TEMPERATURE=0.2

# ─────────────────────────────────────────────────────────────────────────────
# Voice input (D.1.4.8) — endpoint Whisper côté serveur.
# ─────────────────────────────────────────────────────────────────────────────
# Le mobile choisit son moteur via la variable Dart ASSISTANCE_VOICE_ENGINE :
#   - native (défaut) : transcription locale iOS/Android, ZERO appel serveur.
#   - whisper : upload audio vers POST /api/app/assistance/voice/transcribe
#               qui appelle l'API OpenAI Whisper (coût par minute audio).
#
# Kill-switch côté serveur. Désactivé par défaut pour éviter des coûts
# inattendus si un build mobile est paramétré sur whisper par erreur.
# ASSISTANCE_VOICE_WHISPER_ENABLED=true
#
# Modèle Whisper. Par défaut whisper-1 (le seul GA chez OpenAI).
# ASSISTANCE_VOICE_WHISPER_MODEL=whisper-1
#
# Taille max du fichier audio uploadé (en bytes). Défaut 10 MB ≈ 10 min
# d'AAC mono 16 kHz. OpenAI Whisper accepte jusqu'à 25 MB.
# ASSISTANCE_VOICE_MAX_BYTES=10485760

# -----------------------------------------------------------------------------
# PRIVY — bridge wallet (`/auth/privy/exchange`).
# Mode jwt : `PRIVY_JWT_VERIFICATION_KEY` (PEM ES256) **ou** `PRIVY_JWKS_URL` (+ kid du JWT).
# Le secret app sert aux appels serveur→Privy si besoin ; la vérif du token user passe par la clé publique.
#
# Production ECS (`arquantix-api`) : `PRIVY_APP_ID` et `PRIVY_JWKS_URL` sont injectés via
# AWS Secrets Manager (`arquantix/prod/privy-app-id`, `arquantix/prod/privy-jwks-url`).
# Mise à jour : `./scripts/arquantix-sync-privy-secrets.sh`
# -----------------------------------------------------------------------------
# PRIVY_EXCHANGE_VERIFICATION_MODE=jwt   # prod / staging
# PRIVY_EXCHANGE_VERIFICATION_MODE=stub # local si PORTAL_PRIVY_OTP_DEV_MOCK_ENABLED=true
# PRIVY_APP_ID=
# Portail web Next.js (npm run dev — lu via next.config.js + docker-compose build args)
# NEXT_PUBLIC_PRIVY_APP_ID=   # même valeur que PRIVY_APP_ID
# PRIVY_WEB_CLIENT_ID=        # client Web Privy (client-…), pas le client mobile Flutter
# NEXT_PUBLIC_PRIVY_WEB_CLIENT_ID=
# PRIVY_APP_SECRET=
# PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/<APP_ID>/jwks.json
# PRIVY_JWT_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
#
# Ledger dépôts on-chain (webhooks Svix) — voir docs/arquantix/PRIVY_PROD_GO_LIVE.md
# PRIVY_WEBHOOK_VERIFICATION_MODE=svix
# PRIVY_WEBHOOK_SECRET=whsec_...
# Prod ECS Secrets Manager : arquantix/prod/privy-webhook-secret, arquantix/prod/privy-app-secret
# Webhook URL prod : https://api.arquantix.com/api/webhooks/privy (event wallet.funds_deposited)
# Sync secrets : ./scripts/arquantix-sync-privy-secrets.sh

# -----------------------------------------------------------------------------
# LI.FI — swaps DEX / bridges (custody Privy → échange décentralisé).
# Backend uniquement — ne jamais exposer côté Next.js / mobile.
# Dashboard : https://portal.li.fi/ — intégration « vancelian.finance »
# -----------------------------------------------------------------------------
# LIFI_API_KEY=
# LIFI_BASE_URL=https://li.quest/v1
# LIFI_INTEGRATOR_ID=vancelian.finance
# LIFI_INTEGRATION_URL=https://app.vancelian.finance/
# LIFI_FEE_BPS=25
# LIFI_RPM_LIMIT=100
# SWAP_FEE_BPS=0
# Mocks DeFi (npm run dev / API hôte). Le conteneur arquantix-web (NODE_ENV=production) les ignore — voir docker-compose.arquantix-recovery.yml.
# LIFI_SWAPS_MOCK=1
# SWAP_V1_SAME_CHAIN_ONLY=1
# SWAP_V1_PILOT_CHAINS=base,ethereum
# DEFAULT_SLIPPAGE_BPS=50
# LIFI_SWAPS_ENABLED=1

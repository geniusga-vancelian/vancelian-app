{
  "family": "arquantix-coming-soon",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::411714852748:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::411714852748:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "arquantix-coming-soon",
      "image": "411714852748.dkr.ecr.me-central-1.amazonaws.com/arquantix-coming-soon:placeholder",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/arquantix-coming-soon",
          "awslogs-region": "me-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}

# =============================================================================
# Arquantix API — variables sécurité / auth (référence)
# Source de vérité logique : services/security/security_env.py
# =============================================================================

# --- Identité d’environnement (priorité : APP_ENV → ARQUANTIX_ENV → ENVIRONMENT → ENV)
# Valeurs canoniques recommandées : development | test | staging | production
# Alias acceptés : dev→development, prod→production, stage→staging, live→production
APP_ENV=development

# --- OTP dev (jamais en prod-like : APP_ENV production/staging via get_normalized_app_env)
# TWO_FACTOR_DEV_FIXED_CODE=111111
# TWO_FACTOR_DEV_EXPOSE_CODE=false
# TWO_FACTOR_RELAXED=false

# --- Connexion mobile / admin
# AUTH_PASSKEYS_ENABLED=true
# AUTH_MOBILE_OTP_LOGIN_ENABLED=false
# AUTH_ADMIN_EMAIL_OTP_ENABLED=false

# --- WebAuthn
# WEBAUTHN_STRICT_CONFIG=false
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGINS=http://localhost:8011,http://127.0.0.1:8011

# --- Rate limiting auth
# AUTH_REDIS_ENV_STRATEGY=legacy
#   legacy : Redis obligatoire si ENVIRONMENT/ENV ∈ production|prod|live (historique, ignore APP_ENV seul)
#   normalized : Redis obligatoire si APP_ENV (normalisé) = production
# AUTH_RL_BACKEND=auto
# AUTH_REDIS_URL=redis://127.0.0.1:6379/1

# --- Événements & stratégie login
# AUTH_SECURITY_EVENTS_ENABLED=true
# AUTH_DEVICE_FINGERPRINT_ENABLED=true
# LOGIN_DEVICE_TRUST_ENABLED=true
# LOGIN_AUTH_STRATEGY_ENABLED=true
# ADAPTIVE_AUTH_ENABLED=false
# SESSION_INTELLIGENCE_ENABLED=false
# CONTINUOUS_AUTH_ENABLED=false

# --- PR F — risk engine antifraude (désactivé par défaut)
# DEVICE_RISK_ENGINE_PR_F_ENABLED=false
# DEVICE_RISK_ALLOW_THRESHOLD=40
# DEVICE_RISK_STEP_UP_THRESHOLD=40
# DEVICE_RISK_BLOCK_THRESHOLD=70
# DEVICE_RISK_ATTESTATION_STALE_DAYS=30
# DEVICE_RISK_ENGINE_PR_F_CACHE_TTL_SEC=0

# --- PR F.2 — règles combinées + baseline + score pondéré (désactivés par défaut)
# DEVICE_RISK_ENABLE_COMBINATION_RULES=false
# DEVICE_RISK_ENABLE_BASELINE=false
# DEVICE_RISK_USE_WEIGHTED_SCORE=false
# DEVICE_RISK_WEIGHT_DEVICE=0.3
# DEVICE_RISK_WEIGHT_NETWORK=0.2
# DEVICE_RISK_WEIGHT_BEHAVIOR=0.3
# DEVICE_RISK_WEIGHT_HISTORY=0.2
# DEVICE_RISK_BASELINE_MIN_SAMPLES=5

# --- PR F.3 — baseline temporelle (Welford + last 10 actions)
# DEVICE_RISK_ENABLE_ADVANCED_BASELINE=false
# DEVICE_RISK_BASELINE_TIME_WEIGHT=1.0
# DEVICE_RISK_ADVANCED_BASELINE_MIN_SAMPLES=8

# --- PR F.4 — règles dynamiques (table auth_risk_rules, seed migration 138)
# DEVICE_RISK_ENABLE_DYNAMIC_RULES=false

# --- SMS (prod-like : pas de fake)
# FAKE_SMS_PROVIDER=false

# --- SIEM / sink
# SECURITY_EVENTS_SINK=none

# Copier vers .env.flutter (non versionné) et remplir.
# Les scripts ./run-ios.sh, ./run-android.sh, ./run.sh, ./run-ios-device.sh
# chargent ce fichier automatiquement (export des variables puis --dart-define).

# --- BFF Next + API auth (facultatif : les scripts ont sinon des défauts par plate-forme)
# API_BASE_URL=http://127.0.0.1:3000
# AUTH_API_BASE_URL=http://127.0.0.1:8000

# --- Privy (obligatoire pour le bouton « Create wallet » sur le dashboard / clé `more`)
PRIVY_APP_ID=
PRIVY_APP_CLIENT_ID=
PRIVY_OAUTH_SCHEME=vancelian

# Mock OTP Privy (login e-mail) — code fixe, pas d’e-mail Privy
# PORTAL_PRIVY_OTP_DEV_MOCK_ENABLED=true
# PORTAL_PRIVY_OTP_DEV_FIXED_CODE=111111
# API locale : PRIVY_EXCHANGE_VERIFICATION_MODE=stub dans .env.arquantix / api/.env

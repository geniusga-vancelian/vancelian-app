  last_country           String?  @db.VarChar(8)
  trust_score            Int      @default(0)
  trust_level            String   @default("LOW") @db.VarChar(16)
  is_primary             Boolean?
  last_auth_strength     String?  @db.VarChar(64)
  last_attestation_level String?  @db.VarChar(64)
  updated_at             DateTime @default(now()) @db.Timestamptz(6)

  @@unique([user_id, device_hash], map: "uq_auth_user_device_profiles_user_device")
  @@index([device_hash], map: "ix_auth_user_device_profiles_device_hash")
  @@index([user_id], map: "ix_auth_user_device_profiles_user_id")
}

model auth_user_intent_events {
  id          String   @id @db.Uuid
  user_id     Int
  device_id   String   @db.VarChar(128)
  action_type String   @db.VarChar(64)
  metadata    Json     @default("{}")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id, created_at(sort: Desc)], map: "ix_auth_user_intent_events_user_created")
}

model auth_user_risk_baselines {
  user_id                  Int      @id
  primary_country          String?  @db.VarChar(8)
  countries_json           Json     @default("{}")
  frequent_ips_json        Json     @default("[]")
  device_count_ema         Float    @default(1.0)
  actions_per_hour_ema     Float    @default(0.0)
  baseline_sample_count    Int      @default(0)
  updated_at               DateTime @default(now()) @db.Timestamptz(6)
  avg_hour_of_day          Float?
  std_hour_of_day          Float?
  avg_weekday              Float?
  std_weekday              Float?
  avg_session_duration_sec Float?
  std_session_duration_sec Float?
  last_10_actions_types    Json     @default("[]")
  temporal_welford_json    Json     @default("{}")
}

model auth_user_risk_features {
  user_id    Int      @id
  features   Json     @default("{}")
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model auth_user_temporal_features {
  user_id                  Int      @id
  hour_distribution        Json     @default("{}")
  weekday_distribution     Json     @default("{}")
  action_transition_matrix Json     @default("{}")
  ema_activity_drift       Float?
  activity_rate_ema        Float?
  sample_count             Int      @default(0)
  updated_at               DateTime @default(now()) @db.Timestamptz(6)
}

model auth_webauthn_challenges {
  id            String   @id @db.Uuid
  challenge_b64 String   @unique(map: "ix_auth_webauthn_challenges_challenge_b64") @db.VarChar(512)
  flow_type     String   @db.VarChar(32)
  user_id       Int?
  identifier    String?  @db.VarChar(255)
  expires_at    DateTime @db.Timestamptz(6)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  @@index([expires_at], map: "ix_auth_webauthn_challenges_expires_at")
}

model client_operation_statement_snapshots {
  id             String   @id @db.Uuid
  client_id      String   @db.Uuid
  source_system  String   @db.VarChar(20)
  source_id      String   @db.Uuid
  schema_version String   @db.VarChar(32)
  payload_json   Json
  content_sha256 String
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  pdf_sha256     String?

  @@unique([client_id, source_system, source_id], map: "uq_client_operation_statement_snapshots_client_source")
  @@index([client_id], map: "ix_client_operation_statement_snapshots_client_id")
}

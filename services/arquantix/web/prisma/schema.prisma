/// **UI strings remote bundle** — overrides CMS des strings ARB Flutter.
///
/// Pattern fintech (Revolut/Lokalise) : la source de vérité texte reste les
/// fichiers `app_*.arb` Flutter (compilés dans le binaire, garantissent
/// offline + cold start). La table `cms_ui_strings` stocke uniquement les
/// **overrides** par `(key, locale, status)`, exposés via `/api/mobile/flutter/ui-strings`
/// et fusionnés par le runtime Dart `RemoteStringsService` au-dessus de
/// `AppLocalizations`.
///
/// Workflow identique à `SectionContent` : DRAFT en édition admin, copie
/// vers PUBLISHED au moment de "Publier". Bundle public = PUBLISHED only.
///
/// La `key` suit la taxonomie hiérarchique `<namespace>.<section>.<element>`
/// (ex. `common.invest`, `module.my_account.title`, `screen.dashboard.heroSubtitle`,
/// `error.payment.insufficientFunds`). Voir `src/lib/i18n/uiStrings/keyTaxonomy.ts`.
model CmsUiString {
  id        String        @id @default(cuid())
  /// Clé hiérarchique (ex. `module.my_account.title`). **Immutable** une fois publiée.
  key       String
  /// Premier segment de `key` (ex. `common`, `module`, `screen`, `error`) — dénormalisé pour filtrage admin rapide.
  namespace String
  /// Code BCP-47 (`en`, `fr`, …). Aligné sur `app_settings.supported_locales`.
  locale    String
  /// Override texte. Si `value === sourceText` → équivaut à pas d'override (l'app utilisera son fallback ARB).
  value     String        @db.Text
  /// Snapshot de la valeur ARB de la **locale source** (defaultLocale) au moment de l'extraction. Sert de référence aux traducteurs (et au diff "override vs source").
  sourceText String?      @db.Text
  /// Description optionnelle issue du metadata `@key.description` ARB.
  description String?     @db.Text
  /// Placeholders ICU détectés dans la valeur ARB (JSON `{ count: { type: "int" } }`). Sert au validateur côté admin.
  placeholders Json?
  status    ContentStatus
  /// Statut de traduction (cohérent avec `SectionContent.translationStatus`).
  translationStatus TranslationStatus @default(ORIGINAL) @map("translation_status")
  /// Origine de l'enregistrement : `arb_extract`, `manual`, `lokalise_pull`. Auditable.
  source    String        @default("arb_extract")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedByUserId String? @map("updated_by_user_id")
  updatedBy User?         @relation("CmsUiStringEditor", fields: [updatedByUserId], references: [id])

  @@unique([key, locale, status])
  @@index([namespace, locale, status])
  @@index([locale, status])
  @@index([key])
  @@map("cms_ui_strings")
}


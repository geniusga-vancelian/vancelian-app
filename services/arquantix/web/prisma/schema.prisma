generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id                         Int       @id @default(autoincrement())
  /// Nullable (PR4) — index unique partiel SQL : voir migration 130.
  email                      String?   @db.VarChar(255)
  hashedPassword             String    @map("hashed_password") @db.VarChar(255)
  createdAt                  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// -------- Colonnes ajoutées par migrations Alembic (114, 116, 117, 119, 120, 127) --------
  /// Mirrorées ici pour que `prisma db push` ne les supprime pas — non utilisées
  /// directement par le code TypeScript (gérées par le backend Python).
  securityAccountLockedUntil DateTime? @map("security_account_locked_until") @db.Timestamptz(6)
  securityFlagged            Boolean   @default(false) @map("security_flagged")
  securityRefreshBlocked     Boolean   @default(false) @map("security_refresh_blocked")
  zeroTrustRole              String    @default("admin") @map("zero_trust_role") @db.VarChar(32)
  mobileE164                 String?   @map("mobile_e164") @db.VarChar(24)
  personId                   String?   @unique(map: "ix_admin_users_person_id") @map("person_id") @db.Uuid
  mobileAppAllowed           Boolean   @default(true) @map("mobile_app_allowed")
  /// Compte CMS Next (au plus un) lié pour le BFF — pas de résolution JWT par email.
  cmsUser                    User?
  person                     Persons?  @relation("AdminUserPerson", fields: [personId], references: [id], onUpdate: NoAction, map: "fk_admin_users_person_id_persons")
  assistanceAgentDecisionsReviewed AssistanceAgentDecision[]

  /// Unicité côté Prisma Client. En base Alembic 130, l’index partiel reste `ix_admin_users_email` ; ce nom Prisma évite le conflit `db push` (CREATE … already exists).
  @@unique([email], map: "uq_prisma_admin_users_email")
  @@index([id], map: "ix_admin_users_id")
  @@map("admin_users")
}

/// Règles dynamiques PR F.4 (table créée par Alembic). Déclarée ici pour que `prisma db push` ne supprime pas `auth_risk_rules`.
model AuthRiskRules {
  id         String   @id @db.Uuid
  name       String?  @db.VarChar(128)
  priority   Int      @default(100)
  conditions Json     @db.JsonB
  action     String   @db.VarChar(16)
  enabled    Boolean  @default(true)
  version    Int      @default(1)
  isActive   Boolean  @default(true) @map("is_active")
  ruleset    String   @default("default") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([priority], map: "ix_auth_risk_rules_priority")
  @@index([enabled], map: "ix_auth_risk_rules_enabled")
  @@index([ruleset, isActive, priority], map: "ix_auth_risk_rules_ruleset_active_priority")
  @@map("auth_risk_rules")
}

model AlembicVersion {
  versionNum String @id(map: "alembic_version_pkc") @map("version_num") @db.VarChar(32)

  @@map("alembic_version")
}

model AppRuntimeSettings {
  id        String   @id @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     String?  @db.VarChar(500)
  metadata  Json?    @map("metadata_")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("app_runtime_settings")
}

model AppSettings {
  id                   String   @id
  supportedLocales     String   @default("[\"fr\",\"en\",\"ar\",\"it\"]") @map("supported_locales")
  defaultLocale        String   @default("fr") @map("default_locale")
  multilingualEnabled  Boolean  @default(true) @map("multilingual_enabled")
  translationGlossary  Json?    @map("translation_glossary")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model ArticleBlockI18n {
  id                String            @id @default(cuid())
  blockId           String            @map("block_id")
  locale            String
  data              Json
  translationStatus TranslationStatus @default(ORIGINAL) @map("translation_status")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  block             ArticleBlock      @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, locale])
  @@index([blockId])
  @@index([locale])
  @@map("article_block_i18n")
}

model ArticleBlock {
  id        String             @id @default(cuid())
  articleId String             @map("article_id")
  order     Int                @default(0)
  type      ArticleBlockType
  data      Json
  createdAt DateTime           @default(now()) @map("created_at")
  i18n      ArticleBlockI18n[]
  article   Article            @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, order])
  @@index([articleId])
  @@map("article_blocks")
}

model ArticleCategory {
  id        String                @id @default(cuid())
  slug      String                @unique
  label     String
  order     Int                   @default(0)
  isActive  Boolean               @default(true) @map("is_active")
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")
  i18n      ArticleCategoryI18n[]

  @@index([isActive, order])
  @@index([slug])
  @@map("article_categories")
}

model ArticleCategoryI18n {
  id                String            @id @default(cuid())
  categoryId        String            @map("category_id")
  locale            String
  label             String
  translationStatus TranslationStatus @default(ORIGINAL) @map("translation_status")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  category          ArticleCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([categoryId])
  @@index([locale])
  @@map("article_category_i18n")
}

model ArticleI18n {
  id                String            @id @default(cuid())
  articleId         String            @map("article_id")
  locale            String
  title             String
  standfirst        String
  metaTitle         String?           @map("meta_title")
  metaDescription   String?           @map("meta_description")
  translationStatus TranslationStatus @default(ORIGINAL) @map("translation_status")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  coverTitle        String?           @map("cover_title")
  article           Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([articleId])
  @@map("article_i18n")
}

model ArticleLink {
  id        String          @id @default(cuid())
  articleId String          @map("article_id")
  kind      ArticleLinkKind
  targetId  String          @map("target_id")
  createdAt DateTime        @default(now()) @map("created_at")
  article   Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, kind, targetId])
  @@index([articleId])
  @@index([kind, targetId])
  @@map("article_links")
}

model ArticleProject {
  id        String   @id @default(cuid())
  articleId String   @map("article_id")
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([articleId, projectId])
  @@index([articleId])
  @@index([projectId])
  @@map("article_projects")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Article {
  id                  String             @id @default(cuid())
  slug                String             @unique
  status              ContentStatus      @default(DRAFT)
  publishedAt         DateTime?          @map("published_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  coverMediaId        String?            @map("cover_media_id")
  authorName          String             @map("author_name")
  authorRole          String?            @map("author_role")
  allowComments       Boolean            @default(false) @map("allow_comments")
  coverTitle          String?            @map("cover_title")
  coverCredit         String?            @map("cover_credit")
  coverSource         String?            @map("cover_source")
  galleryMediaIds     Json?              @map("gallery_media_ids")
  videoUrl            String?            @map("video_url")
  categorySlugs       Json?              @map("category_slugs")
  documents           Json?
  isFeatured          Boolean            @default(false) @map("is_featured")
  isHighlighted       Boolean            @default(false) @map("is_highlighted")
  isMilestone         Boolean            @default(false) @map("is_milestone")
  /// Actualité entreprise (Vancelian). Uniquement pour `articleType` NEWS ; ANALYSIS/RESEARCH restent false.
  isCompanyNews       Boolean            @default(false) @map("is_company_news")
  articleType         String             @default("NEWS") @map("article_type")
  // -------- Champs spécifiques HELP (Phase 3 unification) --------
  // N'ont de sens que lorsque `articleType = 'HELP'`. Garantis cohérents
  // côté API ; aucune contrainte CHECK SQL pour rester réversible.
  helpCollectionId    String?            @map("help_collection_id")
  helpCategoryId      String?            @map("help_category_id")
  /// Slug d'origine côté hiérarchie Help (avant préfixage technique du `slug` global).
  /// Utilisé par l'URL publique `/help/[collection]/[helpSlug]`.
  helpSlug            String?            @map("help_slug")
  allowAnchors        Boolean            @default(true) @map("allow_anchors")
  targetTags          Json?              @map("target_tags")
  /// Slugs de « tags catégorie » pour regrouper les articles sous une collection (Help, Academy, etc.).
  /// Tableau JSON `["slug-tag", …]` ; pas de table admin séparée — les tags émergent du contenu.
  collectionTags      Json               @default("[]") @map("collection_tags")
  // ---------------------------------------------------------------
  // -------- Champs spécifiques ACADEMY (Phase 4 — pédagogie produit) --------
  // N'ont de sens que lorsque `articleType = 'ACADEMY'`. Symétriques aux
  // champs `help*` ci-dessus. Pas d'AcademyArticle legacy : Academy démarre
  // directement sur Article unifié.
  academyCollectionId String?            @map("academy_collection_id")
  academyCategoryId   String?            @map("academy_category_id")
  /// Slug d'origine côté hiérarchie Academy (URL publique
  /// `/academy/[collection]/[academySlug]`).
  academySlug         String?            @map("academy_slug")
  // -------------------------------------------------------------------------
  blocks              ArticleBlock[]
  i18n                ArticleI18n[]
  articleLinks        ArticleLink[]
  projects            ArticleProject[]
  coverMedia          Media?             @relation(fields: [coverMediaId], references: [id], onDelete: Restrict)
  helpCollection      HelpCollection?    @relation("HelpCollectionUnifiedArticles", fields: [helpCollectionId], references: [id], onDelete: Restrict)
  helpCategory        HelpCategory?      @relation("HelpCategoryUnifiedArticles", fields: [helpCategoryId], references: [id], onDelete: Restrict)
  academyCollection   AcademyCollection? @relation("AcademyCollectionUnifiedArticles", fields: [academyCollectionId], references: [id], onDelete: Restrict)
  academyCategory     AcademyCategory?   @relation("AcademyCategoryUnifiedArticles", fields: [academyCategoryId], references: [id], onDelete: Restrict)

  /// Unicité `(help_collection_id, help_slug)` et `(academy_collection_id, academy_slug)` :
  /// index partiels SQL — voir migration `20260501140000_article_collection_tags`.
  @@index([articleType])
  @@index([isCompanyNews])
  @@index([isFeatured])
  @@index([isHighlighted])
  @@index([isMilestone])
  @@index([publishedAt])
  @@index([status])
  @@index([helpCategoryId])
  @@index([helpCollectionId])
  @@index([academyCategoryId])
  @@index([academyCollectionId])
  @@map("articles")
}

model AuditEvents {
  id            String   @id @db.Uuid
  personId      String   @map("person_id") @db.Uuid
  eventType     String   @map("event_type")
  actorType     String   @map("actor_type")
  actorId       String?  @map("actor_id")
  correlationId String?  @map("correlation_id") @db.Uuid
  payload       Json     @default("{}")
  schemaVersion Int      @default(1) @map("schema_version")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  persons       Persons  @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([correlationId], map: "ix_audit_events_correlation_id")
  @@index([eventType], map: "ix_audit_events_event_type")
  @@index([payload], map: "ix_audit_events_payload", type: Gin)
  @@index([personId, createdAt], map: "ix_audit_events_person_id_created_at")
  @@map("audit_events")
}

/// Assistance « sur mesure » mobile (Search Screen Flutter) — MVP D.1.1.
/// Tables miroir Alembic 144 ; lecture/écriture via FastAPI Python uniquement,
/// déclarées ici pour que `prisma db push` ne les supprime pas.
model AssistanceConversation {
  id                     String              @id @db.Uuid
  clientId               String              @map("client_id") @db.Uuid
  title                  String?
  status                 String              @default("active") @db.VarChar(16)
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  lastMessageAt          DateTime?           @map("last_message_at") @db.Timestamptz(6)
  lastAssistantMessageAt DateTime?           @map("last_assistant_message_at") @db.Timestamptz(6)
  lastReadAt             DateTime?           @map("last_read_at") @db.Timestamptz(6)
  /// Palier 2 D.2.1 — résumé narratif (rolling summary) maintenu par un agent LLM.
  conversationSummary    String?             @map("conversation_summary")
  /// Palier 2 D.2.2 — faits structurés extraits ([{type, value, confidence, source_turn}]).
  conversationFacts      Json                @default("[]") @map("conversation_facts")
  /// Palier 2 D.2.1 — turn_index du dernier tour absorbé par le summary.
  summarizedUntilTurn    Int?                @map("summarized_until_turn")
  /// Palier 2 D.2.1 — horodatage de la dernière consolidation mémoire.
  summaryUpdatedAt       DateTime?           @map("summary_updated_at") @db.Timestamptz(6)
  /// Phase 2 wiki v1.4 — sujet actif (migration Alembic 150).
  currentTopic           Json?               @map("current_topic") @db.JsonB
  peClients              PeClients           @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assistanceMessages     AssistanceMessage[]
  assistanceActionDrafts AssistanceActionDraft[]
  assistanceAgentDecisions AssistanceAgentDecision[]
  assistanceFloatingParameters AssistanceFloatingParameter[]
  discoveryProjectsSource AssistanceClientDiscoveryProject[]

  @@index([clientId, lastMessageAt], map: "ix_assistance_conversations_client_last")
  @@index([clientId, status], map: "ix_assistance_conversations_client_status")
  @@map("assistance_conversations")
}

model AssistanceMessage {
  id                     String                 @id @db.Uuid
  conversationId         String                 @map("conversation_id") @db.Uuid
  turnIndex              Int                    @map("turn_index")
  role                   String                 @db.VarChar(16)
  content                String
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  // Multi-agents Phase 1 (cf. docs/arquantix/MULTI_AGENTS.md, migration 147).
  agentUsed              String?                @map("agent_used") @db.VarChar(32)
  messageType            String                 @default("text") @map("message_type") @db.VarChar(16)
  messagePayload         Json?                  @map("message_payload")
  assistanceConversation AssistanceConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assistanceAgentDecisions AssistanceAgentDecision[]

  @@unique([conversationId, turnIndex], map: "uq_assistance_messages_conversation_turn")
  @@index([conversationId, createdAt], map: "ix_assistance_messages_conversation_created")
  @@index([agentUsed], map: "ix_assistance_messages_agent_used")
  @@map("assistance_messages")
}

/// Catalogue CAL (Alembic 155) — parcours transactionnels édités en admin ; runtime Python.
model AssistanceActionPlaybook {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actionKey        String   @unique(map: "uq_assistance_action_playbooks_action_key") @map("action_key") @db.VarChar(64)
  label            String   @db.VarChar(200)
  description      String?  @db.Text
  transactionKind  String   @map("transaction_kind") @db.VarChar(32)
  agentId          String   @default("product") @map("agent_id") @db.VarChar(32)
  definition       Json     @default("{}") @db.JsonB
  isEnabled        Boolean  @default(true) @map("is_enabled")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isEnabled, sortOrder], map: "ix_assistance_action_playbooks_enabled_sort")
  @@map("assistance_action_playbooks")
}

/// Phase 2a multi-agents — audit trail des décisions agentiques.
/// Cf. `docs/arquantix/MULTI_AGENTS_RUNTIME.md` § 4 et migration Alembic 148.
/// Table « miroir » : gérée par Alembic côté Python, déclarée ici pour
/// que `prisma db push` ne la supprime pas.
model AssistanceAgentDecision {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId    String    @map("conversation_id") @db.Uuid
  messageId         String?   @map("message_id") @db.Uuid
  agentId           String    @map("agent_id") @db.VarChar(32)
  iteration         Int       @db.SmallInt
  toolName          String    @map("tool_name") @db.VarChar(64)
  /// Niveau d'autonomie : 'L0' | 'L1' | 'L2' | 'L3' (CHECK contraint en SQL).
  autonomyLevel     String    @map("autonomy_level") @db.VarChar(4)
  argumentsJson     Json      @default("{}") @map("arguments_json")
  resultSummary     Json?     @map("result_summary")
  proposedAction    String?   @map("proposed_action") @db.VarChar(64)
  targetClientId    String?   @map("target_client_id") @db.Uuid
  targetPersonId    String?   @map("target_person_id") @db.Uuid
  /// Résumé sanitizé anti-tipping-off (cf. RUNTIME § 4.3).
  reasoningSummary  String?   @map("reasoning_summary")
  /// Statut review : 'auto' (L0/L2 immédiat) | 'pending' (L1 attend humain)
  ///                 | 'approved' | 'rejected' (CHECK contraint en SQL).
  reviewStatus      String    @default("auto") @map("review_status") @db.VarChar(16)
  reviewedBy        Int?      @map("reviewed_by")
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamptz(6)
  durationMs        Int?      @map("duration_ms")
  errorCode         String?   @map("error_code") @db.VarChar(32)
  correlationId     String?   @map("correlation_id") @db.VarChar(64)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Cognitive Bot v4 — colonnes dénormalisées (migration Alembic 152).
  emotionalIntent     String?   @map("emotional_intent") @db.VarChar(32)
  conversationStage   String?   @map("conversation_stage") @db.VarChar(16)
  knowledgeLevel      String?   @map("knowledge_level") @db.VarChar(8)
  trustLevel          Float?    @map("trust_level")
  primaryGoal         String?   @map("primary_goal") @db.VarChar(16)
  nextBestAction      String?   @map("next_best_action") @db.VarChar(20)

  assistanceConversation AssistanceConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_assistance_agent_decisions_conversation_id")
  assistanceMessage      AssistanceMessage?     @relation(fields: [messageId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_assistance_agent_decisions_message_id")
  targetPeClient         PeClients?             @relation("AssistanceAgentDecisionTargetClient", fields: [targetClientId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_assistance_agent_decisions_target_client")
  targetPerson           Persons?               @relation("AssistanceAgentDecisionTargetPerson", fields: [targetPersonId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_assistance_agent_decisions_target_person")
  reviewedByAdmin        AdminUser?             @relation(fields: [reviewedBy], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_assistance_agent_decisions_reviewed_by")

  @@index([conversationId, iteration], map: "ix_assistance_agent_decisions_conv_iter")
  @@index([agentId, createdAt], map: "ix_assistance_agent_decisions_agent_created")
  @@index([toolName], map: "ix_assistance_agent_decisions_tool_name")
  @@index([autonomyLevel], map: "ix_assistance_agent_decisions_autonomy_level")
  @@index([targetClientId, createdAt], map: "ix_assistance_agent_decisions_target_client")
  @@map("assistance_agent_decisions")
}

/// Brouillon transactionnel CAL (Alembic 154) — audit runtime Python.
model AssistanceActionDraft {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  actionType     String   @map("action_type") @db.VarChar(64)
  status         String   @default("draft") @db.VarChar(32)
  payload        Json     @default("{}") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  assistanceConversation AssistanceConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  peClients              PeClients              @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversationId], map: "ix_assistance_action_drafts_conversation_id")
  @@index([clientId, createdAt(sort: Desc)], map: "ix_assistance_action_drafts_client_created")
  @@map("assistance_action_drafts")
}

/// Cognitive Bot v4 — projets client cross-conversation (Alembic 153).
model AssistanceClientDiscoveryProject {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId             String    @map("person_id") @db.Uuid
  conversationIdSource String?   @map("conversation_id_source") @db.Uuid
  label                String    @db.VarChar(80)
  status               String    @default("active") @db.VarChar(16)
  confidence           Float?
  parameters           Json      @default("{}") @db.JsonB
  createdAtTurn        Int?      @map("created_at_turn")
  lastTouchedAtTurn    Int?      @map("last_touched_at_turn")
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  person                       Persons                         @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_acdp_person_id")
  sourceConversation           AssistanceConversation?         @relation(fields: [conversationIdSource], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_acdp_conversation_id_source")
  assistanceFloatingParameters AssistanceFloatingParameter[]

  @@index([conversationIdSource], map: "ix_acdp_conv_source")
  @@index([personId, lastTouchedAtTurn(sort: Desc)], map: "ix_acdp_person_touched")
  @@map("assistance_client_discovery_projects")
}

/// Cognitive Bot v4 — paramètres flottants en attente d'attribution (Alembic 153).
model AssistanceFloatingParameter {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId      String    @map("conversation_id") @db.Uuid
  personId            String    @map("person_id") @db.Uuid
  parameterKind       String    @map("parameter_kind") @db.VarChar(32)
  parameterValue      Json      @default("{}") @map("parameter_value") @db.JsonB
  status              String    @default("pending_attribution") @db.VarChar(24)
  attributedProjectId String?   @map("attributed_project_id") @db.Uuid
  createdAtTurn       Int?      @map("created_at_turn")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt          DateTime? @map("resolved_at") @db.Timestamptz(6)

  assistanceConversation AssistanceConversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_afp_conversation_id")

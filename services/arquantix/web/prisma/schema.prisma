/// Rôle structurel dans l’arborescence CMS (indépendant du `template` de contenu).
enum PageRole {
  STANDARD
  HOME
  PROJECTS_HUB
}

model Page {
  id                 String           @id @default(cuid())
  slug               String           @unique
  createdAt          DateTime         @default(now()) @map("created_at")
  urlPath            String           @unique @map("url_path")
  title              String?
  template           String           @default("homepage")
  description        String?
  updatedAt          DateTime         @updatedAt @map("updated_at")
  themeColor         String           @default("dark") @map("theme_color")
  /// Parent dans l’arborescence éditoriale (null = racine). Pas encore utilisé par le routing public.
  parentId           String?          @map("parent_id")
  parent             Page?            @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children           Page[]           @relation("PageHierarchy")
  /// Ordre parmi les enfants d’un même parent (0 par défaut).
  sortOrder          Int              @default(0) @map("sort_order")
  pageRole           PageRole         @default(STANDARD) @map("page_role")
  /// Indique si la page doit apparaître dans la nav quand celle-ci sera synchronisée sur l’arbre (lot futur).
  showInNav          Boolean          @default(true) @map("show_in_nav")
  /// Si false, la page n’apparaît pas comme enfant dans le méga-menu (reste éligible ailleurs selon `show_in_nav`).
  showInMegaMenu     Boolean          @default(true) @map("show_in_mega_menu")
  /// Icône optionnelle (médiathèque) pour les entrées du méga-menu — pages enfants d’un item primaire.
  navMegaIconMediaId String?          @map("nav_mega_icon_media_id")
  navMegaIconMedia   Media?           @relation("PageNavMegaIcon", fields: [navMegaIconMediaId], references: [id], onDelete: SetNull)
  /// Pages système (ex. home) — garde-fou éditorial.
  isSystemPage       Boolean          @default(false) @map("is_system_page")
  menuItems          MenuItem[]
  sections           Section[]
  packagedProduct    PackagedProduct?
  /// Métadonnées SEO par locale (Phase 2A+) — fallback sur `title` / `description` si absent.
  pageI18n           PageI18n[]

  @@index([parentId], map: "ix_pages_parent_id")
  @@index([parentId, sortOrder], map: "ix_pages_parent_sort")
  @@map("pages")
}

/// Titres / descriptions SEO par langue — unicité `(pageId, locale)`.
model PageI18n {
  id                 String  @id @default(cuid())
  pageId             String  @map("page_id")
  locale             String  @db.VarChar(5)
  title              String?
  description        String?
  ogTitle            String? @map("og_title")
  ogDescription      String? @map("og_description")
  /// Libellé de colonne du méga-menu (ex. « Produits ») — optionnel, localisé.
  navMegaCategory    String? @map("nav_mega_category") @db.VarChar(120)
  /// Sous-titre court méga-menu ; si vide, repli sur `description` SEO.
  navMegaDescription String? @map("nav_mega_description") @db.VarChar(500)
  page               Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale], map: "page_i18n_page_id_locale_key")
  @@map("page_i18n")
}

/// Registre catalogue des produits packagés (contenu editorial = Page Vault Builder).
model PackagedProduct {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String                   @unique
  pageId            String                   @unique @map("page_id")
  productType       PackagedProductType      @map("product_type")
  commercialStatus  PackagedCommercialStatus @map("commercial_status")
  visibility        PackagedVisibility
  featuredRank      Int?                     @map("featured_rank")
  categorySlug      String?                  @map("category_slug")
  tags              Json?
  engineType        PackagedEngineType?      @map("engine_type")
  engineReferenceId String?                  @map("engine_reference_id") @db.VarChar(255)
  legacyProjectId   String?                  @unique @map("legacy_project_id")
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt       DateTime?                @map("published_at") @db.Timestamptz(6)

  page               Page                 @relation(fields: [pageId], references: [id], onDelete: Restrict)
  legacyProject      Project?             @relation("PackagedProductLegacyProject", fields: [legacyProjectId], references: [id], onDelete: SetNull)
  lendingPoolProduct LendingPoolProducts?

  @@index([productType], map: "ix_packaged_products_product_type")
  @@index([visibility], map: "ix_packaged_products_visibility")
  @@index([commercialStatus], map: "ix_packaged_products_commercial_status")
  @@index([productType, featuredRank], map: "ix_packaged_products_type_featured")
  @@map("packaged_products")
}


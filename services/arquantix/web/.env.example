# Database (PostgreSQL)
DATABASE_URL="postgresql://arquantix:arquantix@localhost:5443/arquantix_admin"

# Prisma Configuration
# PRISMA_MODE=local (default, uses standard Prisma client)
# PRISMA_MODE=accelerate (uses Prisma Accelerate, requires PRISMA_ACCELERATE_URL)
PRISMA_MODE=local
# PRISMA_ACCELERATE_URL="prisma+postgres://..." (optional, for production/accelerate mode)

# Auth
AUTH_SECRET="dev-secret-change-me"

# Admin Seed (for initial super admin creation)
ADMIN_SEED_EMAIL="admin@local.dev"
ADMIN_SEED_PASSWORD="ChangeMeNow123!"

# Next.js
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

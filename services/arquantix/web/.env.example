# Admin /admin/login0 — vidéo de fond (mp4/webm). Préférer ADMIN_LOGIN0_BG_VIDEO (lu au runtime, y compris Docker).
# ADMIN_LOGIN0_BG_VIDEO=https://cdn.example.com/login0-bg.mp4
# NEXT_PUBLIC_ADMIN_LOGIN0_BG_VIDEO=...  (compat ; souvent figé au build en prod Docker)

# FastAPI — routes serveur Next (BFF) qui font fetch() côté Node : `src/lib/backend.ts`
# Priorité : BACKEND_URL > NEXT_PUBLIC_BACKEND_URL > défaut http://127.0.0.1:8000
# Dev local API sur la machine : laisser vide ou BACKEND_URL=http://127.0.0.1:8000
# Next.js dans Docker, API sur l’hôte : BACKEND_URL=http://host.docker.internal:8000 (voir docker-compose.arquantix.yml)
# BACKEND_URL=http://127.0.0.1:8000

# Database (dev local : Postgres Docker, port hôte = DB_PORT dans .env.arquantix, souvent 5443)
DATABASE_URL="postgresql://arquantix:arquantix@127.0.0.1:5443/arquantix_fresh"

# BFF JWT (Next → FastAPI) : compte technique pour JWT internes (widgets, feed preview, **routes custody CMS**).
# Doit pointer vers une ligne admin_users dédiée (compte service). Requis pour création comptes EUR Modulr depuis le CMS.
# Vérif DB au démarrage sauf si SKIP_BFF_ANONYMOUS_ADMIN_DB_CHECK=1 (ex. next build sans Postgres).
# BFF_ANONYMOUS_BACKEND_ADMIN_ID=1
# SKIP_BFF_ANONYMOUS_ADMIN_DB_CHECK=0
# Libellé logique du principal service (en-tête X-Actor-Id vers l’API) — optionnel, défaut : cms-custody-service
# CMS_CUSTODY_SERVICE_ACTOR_ID=cms-custody-service

# Welcome Flutter — image d’accueil (GET /api/mobile/flutter/welcome)
# Option A : URL absolue (CDN / R2 public custom domain)
# WELCOME_HERO_IMAGE_URL=https://example.com/mobile/welcome/hero.png
# Option B : clé objet dans le bucket R2 (voir npm run upload:welcome-hero)
# WELCOME_HERO_R2_KEY=mobile/welcome/hero.png
# Si le bucket n’est pas public : URL signée (TTL 7 j)
# WELCOME_HERO_USE_PRESIGNED=true

# Phase 8 — Exclusive Offers : bloquer création via ancien flux Projects + lending create-from-project
# (Vault Builder + Product Registry = voie canonique). Rollback : ADMIN_ALLOW_LEGACY_PROJECT_BASED_EO=true
# ADMIN_BLOCK_PROJECT_BASED_EO=true
# ADMIN_ALLOW_LEGACY_PROJECT_BASED_EO=false
# UI admin (optionnel, figé au build) : NEXT_PUBLIC_ADMIN_BLOCK_PROJECT_BASED_EO=true

# OpenAI Translation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSLATION_TEMPERATURE=0
OPENAI_TRANSLATION_MAX_CHARS=12000

# Admin /admin/login0 — vidéo de fond (mp4/webm). Préférer ADMIN_LOGIN0_BG_VIDEO (lu au runtime, y compris Docker).
# ADMIN_LOGIN0_BG_VIDEO=https://cdn.example.com/login0-bg.mp4
# NEXT_PUBLIC_ADMIN_LOGIN0_BG_VIDEO=...  (compat ; souvent figé au build en prod Docker)

# FastAPI — routes serveur Next (BFF) qui font fetch() côté Node : `src/lib/backend.ts`
# Priorité : BACKEND_URL > NEXT_PUBLIC_BACKEND_URL > défaut http://127.0.0.1:8000
# Dev local API sur la machine : laisser vide ou BACKEND_URL=http://127.0.0.1:8000
# Next.js dans Docker, API sur l’hôte : BACKEND_URL=http://host.docker.internal:8000 (voir docker-compose.arquantix.yml)
# BACKEND_URL=http://127.0.0.1:8000

# Database (dev local : Postgres Docker, port hôte = DB_PORT dans .env.arquantix, souvent 5443)
DATABASE_URL="postgresql://arquantix:arquantix@127.0.0.1:5443/arquantix_fresh"

# Cloudflare R2 — requis pour la bibliothèque médias (upload, GET /api/admin/media/*/file).
# Le dashboard Cloudflare ≠ clés API : crée des jetons sous R2 → Manage R2 API Tokens (S3 API).
# En local : soit ce fichier (web/.env.local), soit le .env à la racine du dépôt (chargé par next.config.js).
# En Docker : le .env racine via env_file du service arquantix-web.
# R2_ENDPOINT=https://xxxxxxxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=arquantix-media
# R2_PUBLIC_URL=

# BFF JWT (Next → FastAPI) : compte technique pour JWT internes (widgets, feed preview, **routes custody CMS**).
# Doit pointer vers une ligne admin_users dédiée (compte service). Requis pour création comptes EUR Modulr depuis le CMS.
# Vérif DB au démarrage sauf si SKIP_BFF_ANONYMOUS_ADMIN_DB_CHECK=1 (ex. next build sans Postgres).
# BFF_ANONYMOUS_BACKEND_ADMIN_ID=1
# SKIP_BFF_ANONYMOUS_ADMIN_DB_CHECK=0
# Libellé logique du principal service (en-tête X-Actor-Id vers l’API) — optionnel, défaut : cms-custody-service
# CMS_CUSTODY_SERVICE_ACTOR_ID=cms-custody-service

# Welcome Flutter — image d’accueil (GET /api/mobile/flutter/welcome)
# Option A : URL absolue (CDN / R2 public custom domain)
# WELCOME_HERO_IMAGE_URL=https://example.com/mobile/welcome/hero.png
# Option B : clé objet dans le bucket R2 (voir npm run upload:welcome-hero)
# WELCOME_HERO_R2_KEY=mobile/welcome/hero.png
# Si le bucket n’est pas public : URL signée (TTL 7 j)
# WELCOME_HERO_USE_PRESIGNED=true

# Phase 8 — Exclusive Offers : bloquer création via ancien flux Projects + lending create-from-project
# (Vault Builder + Product Registry = voie canonique). Rollback : ADMIN_ALLOW_LEGACY_PROJECT_BASED_EO=true
# ADMIN_BLOCK_PROJECT_BASED_EO=true
# ADMIN_ALLOW_LEGACY_PROJECT_BASED_EO=false
# UI admin (optionnel, figé au build) : NEXT_PUBLIC_ADMIN_BLOCK_PROJECT_BASED_EO=true

# URL publique du site (SEO : metadataBase, canonical absolue, Open Graph). Sans slash final.
# Ex. prod : https://www.example.com — en local souvent absent (URLs relatives OK).
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# Portail client web (app.*) — auth Privy whitelabel.
# NEXT_PUBLIC_PRIVY_APP_ID=          # même App ID que Flutter
# NEXT_PUBLIC_PRIVY_WEB_CLIENT_ID=   # app client *Web* requis en local (pas le client mobile Flutter)
# Dashboard Privy → App client Web → Allowed origins : http://localhost:3000 (ou le port WEB_PORT utilisé)
# Dev local : http://localhost:3000/app/login — vérifier GET /api/portal/health (privyWebClientIdConfigured: true)

# Wallet externe (MetaMask / WalletConnect) — Morpho direct + LI.FI sans gas sponsorship Privy
# Créer un projet sur https://cloud.walletconnect.com
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=c81911c59a601f3c793d361a74c1486d
# NEXT_PUBLIC_PORTAL_APP_URL=https://app.vancelian.finance
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
# NEXT_PUBLIC_ETHEREUM_RPC_URL=https://ethereum.publicnode.com

# Morpho USDC — sandbox local (dev uniquement, jamais en production)
# MORPHO_LOCAL_SANDBOX_ENABLED=true
# MORPHO_LOCAL_SANDBOX_YIELD_BPS=450
# Doc : docs/arquantix/MORPHO_LOCAL_SANDBOX.md
# Panneau dev : http://localhost:3000/dev/morpho-sandbox
# MORPHO_LOCAL_SANDBOX_PERSON_EMAIL=morpho-sandbox@local.dev
# MORPHO_LOCAL_SANDBOX_PERSON_ID=
# MORPHO_LOCAL_SANDBOX_WALLET_ADDRESS=0x00000000000000000000000000000000000101
# MORPHO_LOCAL_SANDBOX_PRIVY_WALLET_ID=local_mock_privy_wallet
# Lancer : pnpm morpho:seed-local && pnpm dev → http://localhost:3000/app/invest

# Wallet externe mock local — sans MetaMask / Reown (dev sandbox uniquement)
# Requiert MORPHO_LOCAL_SANDBOX_ENABLED=true ou LIFI_LOCAL_SANDBOX_ENABLED=true
# EXTERNAL_WALLET_LOCAL_MOCK_ENABLED=true
# LIFI_LOCAL_SANDBOX_ENABLED=true
# Panneau dev : http://localhost:3000/dev/wallet-sandbox

# Morpho USDC beta — voir docs/arquantix/MORPHO_BETA_RUNBOOK.md
# MORPHO_USDC_BETA_ENABLED=false

# Ledgity vaults (ERC4626 RWA sur Base) — voir docs/arquantix/LEDGITY_LIVE_RUNBOOK.md
# Production live contrôlé (accès ouvert, plafonds faibles, sans allowlist) :
# LEDGITY_VAULTS_ENABLED=true
# LEDGITY_BETA_ENABLED=false
# LEDGITY_DEPOSITS_DISABLED=false
# LEDGITY_WITHDRAWS_DISABLED=false
# LEDGITY_MAX_DEPOSIT_RAW=10000000
# LEDGITY_MAX_USER_EXPOSURE_RAW=50000000
# LEDGITY_MAX_GLOBAL_EXPOSURE_RAW=500000000
# LEDGITY_MIN_DEPOSIT_RAW=1000000
# LEDGITY_RECONCILIATION_TOLERANCE_RAW=10
# LEDGITY_ALERT_MISMATCH_TOLERANCE_RAW=1000000
# LEDGITY_PENDING_ALERT_MINUTES=15
# LEDGITY_LIQUIDITY_WARNING_RATIO_BPS=1000
# Beta allowlist (désactivé en prod live — laisser false) :
# LEDGITY_BETA_ALLOW_ALL_USERS=false
# LEDGITY_BETA_PERSON_IDS=
# LEDGITY_BETA_EMAILS=

# Ledgity sandbox local (dev uniquement, jamais en production)
# LEDGITY_LOCAL_SANDBOX_ENABLED=true
# LEDGITY_LOCAL_SANDBOX_YIELD_BPS=900
# LEDGITY_LOCAL_SANDBOX_PPS=1.0578
# Doc : docs/arquantix/LEDGITY_LOCAL_SANDBOX.md
# LEDGITY_LOCAL_SANDBOX_PERSON_EMAIL=ledgity-sandbox@local.dev
# LEDGITY_LOCAL_SANDBOX_PERSON_ID=
# LEDGITY_LOCAL_SANDBOX_WALLET_ADDRESS=0x00000000000000000000000000000000000102
# LEDGITY_LOCAL_SANDBOX_PRIVY_WALLET_ID=local_mock_ledgity_wallet
# Lancer : npm run ledgity:seed-vaults && npm run dev → http://localhost:3000/app/invest

# OpenAI Translation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSLATION_TEMPERATURE=0
OPENAI_TRANSLATION_MAX_CHARS=12000
# Mémoire long-terme assistance (Palier 2 D.2). Lue côté API Python.
ASSISTANCE_SUMMARIZER_MODEL=gpt-4o-mini

# Multi-agents assistance (Phase 1, cf. docs/arquantix/MULTI_AGENTS.md).
# Toutes ces vars sont optionnelles — le code Python a des fallbacks.
# ASSISTANCE_MULTI_AGENT_ENABLED=true
# ASSISTANCE_AGENT_ROUTER_MODEL=gpt-4o-mini
# ASSISTANCE_ROUTER_TEMPERATURE=0.1
# ASSISTANCE_ROUTER_CONFIDENCE_MIN=0.5
# ASSISTANCE_AGENT_DEFAULT_MODEL=gpt-4o-mini
# ASSISTANCE_AGENT_COMPLIANCE_MODEL=gpt-4o-mini
# ASSISTANCE_AGENT_ADVISOR_MODEL=gpt-4o
# ASSISTANCE_AGENT_PRODUCT_MODEL=gpt-4o-mini
# ASSISTANCE_AGENT_MARKET_MODEL=gpt-4o-mini
